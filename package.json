{
	"name": "pict-renderer-graph",
	"version": "1.0.0",
	"description": "Headless Excalidraw rendering as a fable service. JSON graph in, hand-drawn SVG (or PNG) out. Drives a pre-warmed Chromium for ~30ms-per-diagram throughput. Usable as a library, CLI, or HTTP service.",
	"main": "source/Pict-Renderer-Graph.js",
	"bin": {
		"pict-renderer-graph": "source/cli/Pict-Renderer-Graph-CLI-Run.js"
	},
	"files": [
		"source/",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"start": "node source/cli/Pict-Renderer-Graph-CLI-Run.js",
		"test": "mocha -u tdd -R spec",
		"tests": "mocha -u tdd -R spec -g",
		"test:e2e": "node test/puppeteer/Service-E2E.js",
		"test:gallery": "node test/puppeteer/Gallery-Generator.js",
		"loadtest": "node scripts/Loadtest.js"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fable-retold/pict-renderer-graph.git"
	},
	"author": "steven velozo <steven@velozo.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/fable-retold/pict-renderer-graph/issues"
	},
	"homepage": "https://github.com/fable-retold/pict-renderer-graph#readme",
	"devDependencies": {
		"chai": "^4.5.0",
		"mocha": "^10.4.0",
		"pict-docuserve": "^1.3.3"
	},
	"mocha": {
		"diff": true,
		"extension": [
			"js"
		],
		"package": "./package.json",
		"reporter": "spec",
		"slow": "75",
		"timeout": "5000",
		"ui": "tdd",
		"watch-files": [
			"source/**/*.js",
			"test/**/*.js"
		],
		"watch-ignore": [
			"node_modules"
		]
	},
	"dependencies": {
		"fable": "^3.1.75",
		"fable-serviceproviderbase": "^3.0.19",
		"lru-cache": "^11.5.0",
		"orator": "^6.1.2",
		"orator-serviceserver-restify": "^2.0.11",
		"pict-section-excalidraw": "file:../pict-section-excalidraw",
		"puppeteer": "^24.43.1"
	}
}
